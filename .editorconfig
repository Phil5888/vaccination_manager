root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Trailing spaces in Markdown are meaningful (line breaks)
[*.md]
trim_trailing_whitespace = false

# Binary assets — never modify
[*.{png,jpg,jpeg,gif,ico,ttf,otf,woff,woff2}]
binary = true
