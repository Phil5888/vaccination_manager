# Normalize all text files to LF on commit (prevents CRLF/LF mixed commits)
* text=auto eol=lf

# Dart / Flutter source
*.dart    text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.arb     text eol=lf
*.md      text eol=lf
*.gradle  text eol=lf
*.xml     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.sh      text eol=lf

# Binary assets — never touch line endings
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary
*.zip     binary
*.jar     binary
*.keystore binary
